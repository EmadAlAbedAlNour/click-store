{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://click-store-backend.vercel.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://click-store-backend.vercel.app/uploads/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
