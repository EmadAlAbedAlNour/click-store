PORT=5000
HOST=0.0.0.0
NODE_ENV=development
# Proxy trust for accurate req.ip / rate limiting behind tunnels or reverse proxies.
# Examples: false | true | 1 | "loopback, linklocal, uniquelocal"
TRUST_PROXY=loopback, linklocal, uniquelocal

# PostgreSQL
DB_CLIENT=postgres
# Option A: full URL
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/click_store
# Option B: discrete vars
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=click_store
PG_SSL=0
PG_SSL_REJECT_UNAUTHORIZED=0
# Current backend transaction pattern requires a single DB connection.
PG_POOL_MAX=1

# Required in production
JWT_SECRET=replace_with_strong_random_secret

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Legacy single-origin alias is still supported by the app:
# CORS_ORIGIN=http://localhost:5173

# Initial admin seed (used only when users table is empty)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=123456
